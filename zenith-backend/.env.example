DB_URL=postgresql+asyncpg://postgres:postgres@localhost/zenith
DB_ECHO=false

SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_JWT_AUDIENCE=authenticated
SUPABASE_JWT_ISSUER=https://tu-proyecto.supabase.co/auth/v1
SUPABASE_JWT_SECRET=tu-jwt-secret

OPENROUTER_API_KEY=tu-openrouter-api-key
OPENROUTER_MODEL=meta-llama/llama-4-maverick

GROQ_API_KEY=tu-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile

AI_CHAT_PROVIDER=groq
AI_CHAT_MODEL=
AI_GENERATION_PROVIDER=openrouter
AI_GENERATION_MODEL=
AI_FALLBACK_ENABLED=true

AI_AGENTIC_ACTIONS_ENABLED=false
AI_CONTEXT_PROFILE_ENABLED=false
AI_CONTEXT_WORKOUT_ENABLED=false
AI_CONTEXT_CLASSES_ENABLED=false
