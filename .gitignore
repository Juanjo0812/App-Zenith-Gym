# Root .gitignore for App Volt-Gym

# Mobile (React Native / Expo)
volt-gym-mobile/node_modules/
volt-gym-mobile/.expo/
volt-gym-mobile/web-build/
volt-gym-mobile/dist/

# Backend (Python / FastAPI)
**/__pycache__/
**/*.pyc
**/*.pyo
**/*.pyd
.venv/
env/
venv/
.pytest_cache/
.coverage
htmlcov/

# Environment files
.env
*.env
.env.*

# OS files
.DS_Store
Thumbs.db
